# Google Sign-In (create OAuth credentials in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google Service Account (read-only access to your Sheet)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
SHEET_ID=

# Mixpanel
MIXPANEL_AUTH_TOKEN=
MIXPANEL_PROJECT_ID=3191947

# Safety net: this email always gets full access, even if the Access sheet
# is broken, empty, or misconfigured. Never leaves you locked out.
SUPER_ADMIN_EMAIL=

# Shown as a "Request access" mailto link on access-denied pages (optional)
NEXT_PUBLIC_ADMIN_EMAIL=

# Postgres over SSH tunnel (only needed if using the Postgres Dashboards section)
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PRIVATE_KEY=
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# AI features (Explain this + chat) - Google Gemini free tier
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
